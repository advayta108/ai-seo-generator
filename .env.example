PORT=3000

# Flowise Prediction API
FLOWISE_BASE_URL=http://localhost:3001
FLOWISE_CHATFLOW_ID=replace-with-chatflow-id
# Optional Flowise API key if the Prediction API is protected.
FLOWISE_API_KEY=
FLOWISE_TIMEOUT_MS=30000

# LLM provider forwarded to Flowise overrideConfig.
# Supported values: claude, openai
# Anthropic/OpenAI API keys are configured in Flowise credentials, not in this API.
FLOWISE_LLM_PROVIDER=claude
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_MODEL=gpt-4o-mini

# Optional Flowise node IDs if your chatflow expects node-scoped overrides.
# Copy it from the node's id in exported Flowise JSON, for example chatAnthropic_0.
# Example: FLOWISE_LLM_NODE_ID=chatAnthropic_0
FLOWISE_LLM_NODE_ID=
